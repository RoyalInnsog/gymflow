# ─────────────────────────────────────────────────────────────────────────────
# RELEASE SIGNING CREDENTIALS  —  TEMPLATE ONLY
# ─────────────────────────────────────────────────────────────────────────────
# 1. Generate a keystore (one-time; keep the .jks file + these passwords SAFE and
#    BACKED UP — losing them means you can never update the app on Play Store).
#    Run this from inside the  android/  folder:
#
#      keytool -genkeypair -v -keystore gymflow-release.jks \
#        -alias gymflow -keyalg RSA -keysize 2048 -validity 10000
#
# 2. Copy this file to  android/keystore.properties  and fill in real values.
# 3. NEVER commit the real keystore.properties or the .jks file (already gitignored).
#
# Paths below are resolved relative to the  android/  folder (rootProject).
# ─────────────────────────────────────────────────────────────────────────────

storeFile=gymflow-release.jks
storePassword=CHANGE_ME
keyAlias=gymflow
keyPassword=CHANGE_ME
