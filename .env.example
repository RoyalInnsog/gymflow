# ==============================================================================
# GYM FLOW ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to '.env' and fill in the values before starting the application.
# NEVER commit the '.env' file to version control.

# ------------------------------------------------------------------------------
# SECURITY & AUTHENTICATION (REQUIRED)
# ------------------------------------------------------------------------------
# JWT_SECRET: The secret key used to sign and verify JSON Web Tokens.
# IMPORTANT: This MUST be a cryptographically secure random string of at least 32 characters.
# DO NOT use "password", "secret", or any default fallback.
# The application will refuse to start if this is missing or weak.
JWT_SECRET=generate_a_secure_random_string_at_least_32_chars_here

# ------------------------------------------------------------------------------
# SERVER SETTINGS
# ------------------------------------------------------------------------------
# PORT: The port the Express server will listen on. Default is 3000.
PORT=3000

# NODE_ENV: Set to 'production' in production environments to enable security features
# (Secure cookies require HTTPS in production).
NODE_ENV=development

# TRUST_PROXY: Set when the app runs BEHIND a reverse proxy / load balancer (nginx,
# Render, Railway, Cloudflare, etc.) so req.ip is the real client IP instead of the
# proxy's. The auth rate limiter keys on req.ip — without this, all users share one
# bucket and can be locked out together. Use '1' to trust the first hop (most setups),
# 'true' to trust all, or a specific subnet. Leave UNSET for direct/local deployments.
# TRUST_PROXY=1

# APP_BASE_URL: Public base URL used to build verification / password-reset links in
# outgoing emails. Falls back to http://localhost:PORT in local dev. [H3]
# APP_BASE_URL=https://app.yourgym.com

# ALLOWED_ORIGINS: Comma-separated list of origins allowed to call the API with
# credentials (CORS). Leave unset for same-origin-only. [H5]
# ALLOWED_ORIGINS=https://app.yourgym.com

# AUTOMATION_INTERVAL_MS: How often background automation scans run for all tenants
# (default 900000 = 15 min). [M6]
# AUTOMATION_INTERVAL_MS=900000

# BACKUP_DIR: Directory for tenant JSON backups. MUST be outside the web root.
# Defaults to ./data/backups. [M7]
# BACKUP_DIR=/var/lib/gymflow/backups

# ------------------------------------------------------------------------------
# PAYMENTS (Razorpay) — secrets come from env only, never the tenant database [M9]
# ------------------------------------------------------------------------------
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
# RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# PLATFORM_UPI_ID: The platform's OWN UPI handle for collecting SaaS subscription
# fees via the "Direct UPI" tab. Must be the corporate/platform account — there is
# NO hardcoded fallback (the Direct-UPI tab hides itself when this is unset).
# Direct-UPI submissions only record a PENDING request; an operator verifies the
# transfer before the plan is activated.
# PLATFORM_UPI_ID=yourcompany@hdfcbank
# PLATFORM_UPI_NAME=GymFlow

# ------------------------------------------------------------------------------
# EMAIL CONFIGURATION (Resend)
# ------------------------------------------------------------------------------
# EMAIL_PROVIDER: The service used for transactional emails.
EMAIL_PROVIDER=resend

# EMAIL_API_KEY: The API key for the email provider.
EMAIL_API_KEY=your_resend_api_key_here

# EMAIL_FROM: The verified sender email address.
EMAIL_FROM=onboarding@resend.dev

# ------------------------------------------------------------------------------
# ------------------------------------------------------------------------------
# WHATSAPP AUTOMATION (whatsapp-web.js — free, no third-party API)
# ------------------------------------------------------------------------------
# Real WhatsApp messages are sent from the gym manager's OWN WhatsApp account after
# a one-time QR scan (Settings → WhatsApp). Sessions are persisted on disk so the
# QR survives restarts. All values below are OPTIONAL and have safe defaults.
#
# WHATSAPP_SESSION_PATH: Folder that stores the linked-account session per tenant.
# MUST be persistent (not a serverless /tmp) and outside the public web root.
# Defaults to ./.wwebjs_auth
# WHATSAPP_SESSION_PATH=/var/lib/gymflow/wwebjs_auth
#
# WHATSAPP_CACHE_PATH: Cache folder for the WhatsApp Web build. Defaults to ./.wwebjs_cache
# WHATSAPP_CACHE_PATH=/var/lib/gymflow/wwebjs_cache
#
# WHATSAPP_HEADLESS: Run the headless browser without a window. Default 'true'.
# Set to 'false' only for local debugging.
# WHATSAPP_HEADLESS=true
#
# WHATSAPP_PUPPETEER_EXECUTABLE_PATH: Use a specific Chrome/Chromium/Edge binary
# instead of the one Puppeteer downloads. Recommended on Windows if the bundled
# Chromium fails to launch (point it at Edge or Chrome).
# WHATSAPP_PUPPETEER_EXECUTABLE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
#
# Outbound queue tuning (sends are serialized one-at-a-time per tenant):
# WHATSAPP_SEND_DELAY_MS=3000     # gap between consecutive messages
# WHATSAPP_MAX_RETRIES=3          # retry attempts for transient send failures
# WHATSAPP_RETRY_DELAY_MS=5000    # wait before each retry

# ------------------------------------------------------------------------------
# GOOGLE OAUTH (optional — enables "Continue with Google" sign-in)
# ------------------------------------------------------------------------------
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI MUST be: {APP_BASE_URL}/api/v1/auth/google/callback
# (e.g. http://localhost:3000/api/v1/auth/google/callback for local dev).
# The "Continue with Google" button auto-hides when these are unset.
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxx
