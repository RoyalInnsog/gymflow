{
  "name": "gym-flow",
  "version": "1.0.0",
  "description": "Gym Flow — multi-tenant gym management SaaS (backend + connected screens)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node tests/run.js",
    "build:css": "tailwindcss -c tailwind.config.js -i ./tailwind.input.css -o ./public/assets/css/tailwind.css --minify",
    "watch:css": "tailwindcss -c tailwind.config.js -i ./tailwind.input.css -o ./public/assets/css/tailwind.css --watch"
  },
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@libsql/client": "^0.17.4",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "16.6.1",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "nodemon": "^3.1.0",
    "sqlite3": "^5.1.7",
    "tailwindcss": "^3.4.17"
  }
