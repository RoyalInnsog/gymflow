node_modules/
.env
database.db
database.sqlite

# SQLite runtime sidecar files (regenerated at runtime; never commit)
database.db-shm
database.db-wal

# [M7] Backups live outside the web root and must never be committed.
data/
backup_*.db
backup_*.json

# Local server logs / scratch
_srv_out.log
_srv_err.log
_*.js

# [WHATSAPP] whatsapp-web.js session credentials & cache — NEVER commit. These hold
# the linked WhatsApp account auth; committing them would expose the account.
.wwebjs_auth/
.wwebjs_cache/

# Archived one-off dev/migration scripts (kept out of the repo root)
archive/

# Pre-refactor DB snapshots
*.bak
database.db.pre_*

# Capacitor / Android wrapper (Phase 3)
mobile/node_modules/
# Android Studio signing credentials — NEVER commit
**/keystore.properties
*.keystore
*.jks

# IDE settings — not part of the app
.idea/
.kiro/

# Local Chromium download — not app source, huge, rebuilt on the server
chrome/

# Scratch / temp test databases
scratch-*.db

# On-device AI model file (~1.9GB) — never commit, GitHub rejects >100MB blobs.
# Distribute separately (e.g. a download step) rather than via git.
public/models/
*.task

# Tenant-uploaded content (logos, etc.) — runtime data, not app source.
public/assets/uploads/
mobile/www/
