{
  "name": "gymflow-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Capacitor Android hybrid for Gym Flow. The full frontend is bundled into www by build-www.js (all pages + assets offline); only /api/v1 traffic goes to the remote backend (API_BASE in build-www.js).",
  "scripts": {
    "build:www": "node build-www.js",
    "sync": "node build-www.js && cap sync android",
    "open": "cap open android",
    "assets": "capacitor-assets generate --android --assetPath assets",
    "build:apk": "cd android && gradlew.bat assembleRelease",
    "build:aab": "cd android && gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5"
  }
}
